rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isEditor() {
      return isAuthenticated() && 
             firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'editor');
    }
    
    function isAuthor() {
      return isAuthenticated() && 
             firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'editor' ||
              firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'author');
    }
    
    function isValidImageType() {
      return request.resource.contentType.matches('image/.*');
    }
    
    function isValidVideoType() {
      return request.resource.contentType.matches('video/.*');
    }
    
    function isValidFileSize(maxSizeInMB) {
      return request.resource.size < maxSizeInMB * 1024 * 1024;
    }
    
    // Articles images - Authors and above can upload
    match /articles/{articleId}/{allPaths=**} {
      allow read: if true; // Public read access for article images
      allow write: if isAuthor() && 
                      (isValidImageType() || isValidVideoType()) &&
                      isValidFileSize(10); // 10MB limit
      allow delete: if isEditor();
    }
    
    // Events images - Authors and above can upload
    match /events/{eventId}/{allPaths=**} {
      allow read: if true; // Public read access for event images
      allow write: if isAuthor() && 
                      (isValidImageType() || isValidVideoType()) &&
                      isValidFileSize(10); // 10MB limit
      allow delete: if isEditor();
    }
    
    // Opportunities images - Authors and above can upload
    match /opportunities/{opportunityId}/{allPaths=**} {
      allow read: if true; // Public read access for opportunity images
      allow write: if isAuthor() && 
                      (isValidImageType() || isValidVideoType()) &&
                      isValidFileSize(10); // 10MB limit
      allow delete: if isEditor();
    }
    
    // Submissions - Anyone can upload (including anonymous users)
    match /submissions/{submissionId}/{allPaths=**} {
      allow read: if isEditor(); // Only editors can view submission files
      allow write: if (isValidImageType() || isValidVideoType()) &&
                      isValidFileSize(5); // 5MB limit for submissions
      allow delete: if isEditor();
    }
    
    // Profile images - Users can upload their own profile images
    match /profiles/{userId}/{allPaths=**} {
      allow read: if true; // Public read access for profile images
      allow write: if isAuthenticated() && 
                      (request.auth.uid == userId || isAdmin()) &&
                      isValidImageType() &&
                      isValidFileSize(2); // 2MB limit for profile images
      allow delete: if isAuthenticated() && 
                       (request.auth.uid == userId || isAdmin());
    }
    
    // System files - Admin only
    match /system/{allPaths=**} {
      allow read, write: if isAdmin();
    }
    
    // Temporary uploads - Authenticated users only, auto-cleanup
    match /temp/{userId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId &&
                            (isValidImageType() || isValidVideoType()) &&
                            isValidFileSize(10); // 10MB limit
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Backups - Admin only
    match /backups/{allPaths=**} {
      allow read, write: if isAdmin();
    }
    
    // Analytics files - Admin only
    match /analytics/{allPaths=**} {
      allow read, write: if isAdmin();
    }
  }
}